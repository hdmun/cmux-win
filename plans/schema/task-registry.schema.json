{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cmux-win.local/plans/task-registry.schema.json",
  "title": "cmux-win task registry",
  "type": "object",
  "required": [
    "schema_version",
    "milestone_id",
    "display_name",
    "depends_on",
    "doc_refs",
    "tasks"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "milestone_id": {
      "type": "string",
      "pattern": "^m[0-9]+$"
    },
    "display_name": {
      "type": "string"
    },
    "depends_on": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^m[0-9]+$"
      }
    },
    "doc_refs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/doc_ref_string"
      }
    },
    "tasks": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/task"
      }
    }
  },
  "$defs": {
    "doc_ref_string": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._\\\\/-]+(?:#[^\\s]+)?$"
    },
    "queue_number": {
      "type": "integer",
      "minimum": 1,
      "maximum": 11
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "ready",
        "in_progress",
        "blocked",
        "done"
      ]
    },
    "task": {
      "type": "object",
      "required": [
        "task_id",
        "queue_number",
        "title",
        "status",
        "summary",
        "depends_on",
        "doc_refs",
        "touches",
        "acceptance",
        "commands",
        "outputs",
        "blocked_by",
        "notes"
      ],
      "properties": {
        "task_id": {
          "type": "string",
          "pattern": "^m[0-9]+-[0-9]+$"
        },
        "queue_number": {
          "$ref": "#/$defs/queue_number"
        },
        "title": {
          "type": "string"
        },
        "status": {
          "$ref": "#/$defs/status"
        },
        "summary": {
          "type": "string"
        },
        "depends_on": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^m[0-9]+-[0-9]+$"
          }
        },
        "doc_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/doc_ref_string"
          }
        },
        "touches": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "acceptance": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "commands": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "outputs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "authoritative_rules": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "blocked_by": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
